# ===========================================
# DEV Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values
# Usage: cd environments/dev && cp .env.dev .env

# -------------------------------------------
# Database Configuration
# -------------------------------------------
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# -------------------------------------------
# JWT & API Keys
# Generate with: ./scripts/generate-keys.sh
# -------------------------------------------
# IMPORTANT: Use a strong secret with at least 32 characters
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long-for-dev

# Generate these using the Supabase CLI or generate-keys.sh script
# For development, you can use these test keys:
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# -------------------------------------------
# Site URLs
# -------------------------------------------
SITE_URL=http://localhost:8080

# -------------------------------------------
# Google OAuth (Optional for DEV)
# -------------------------------------------
GOOGLE_AUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -------------------------------------------
# Edge Function Secrets
# -------------------------------------------
TOKEN_ENCRYPTION_KEY=dev-encryption-key-32-chars-long!
WEBHOOK_SECRET=dev-webhook-secret-for-testing
MAKE_GOOGLE_EMAIL=

# -------------------------------------------
# Frontend Environment Variables
# These are set automatically in podman-compose.yml
# -------------------------------------------
# VITE_SUPABASE_URL=http://localhost:54321
# VITE_SUPABASE_ANON_KEY=${ANON_KEY}
# VITE_SUPABASE_PROJECT_ID=local
# VITE_ENVIRONMENT=development
