# ===========================================
# PRODUCTION Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values
# Usage: cd environments/prod && cp .env.prod .env
#
# ⚠️  WARNING: Use strong, unique values for all secrets!
# ⚠️  Never commit this file with real values to version control!

# -------------------------------------------
# Domain Configuration
# -------------------------------------------
DOMAIN=yourdomain.com
API_DOMAIN=api.yourdomain.com
SITE_URL=https://yourdomain.com
VITE_SUPABASE_URL=https://api.yourdomain.com
REGION=us-east-1

# -------------------------------------------
# SSL Certificates (Let's Encrypt)
# Run: certbot certonly --standalone -d yourdomain.com -d api.yourdomain.com
# -------------------------------------------
SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem

# -------------------------------------------
# Database Configuration
# ⚠️  Use a VERY STRONG password!
# Generate with: openssl rand -base64 32
# -------------------------------------------
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_VERY_STRONG_PASSWORD
POSTGRES_DB=postgres

# -------------------------------------------
# JWT & API Keys
# Generate with: ./scripts/generate-keys.sh
# ⚠️  Keep these secret and unique to production!
# -------------------------------------------
JWT_SECRET=CHANGE_THIS_TO_A_UNIQUE_PRODUCTION_JWT_SECRET_MINIMUM_32_CHARS

# Generate these using the generate-keys.sh script with the JWT_SECRET above
ANON_KEY=GENERATE_WITH_SCRIPT_USING_PRODUCTION_JWT_SECRET
SERVICE_ROLE_KEY=GENERATE_WITH_SCRIPT_USING_PRODUCTION_JWT_SECRET

# -------------------------------------------
# Google OAuth (Production Credentials)
# Create production-specific credentials in Google Cloud Console
# Authorized redirect: https://api.yourdomain.com/auth/v1/callback
# -------------------------------------------
GOOGLE_CLIENT_ID=your-production-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-production-google-client-secret

# -------------------------------------------
# SMTP Configuration (Production Email)
# Use a reliable transactional email provider
# -------------------------------------------
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=your-production-smtp-user
SMTP_PASS=your-production-smtp-password
SMTP_ADMIN_EMAIL=noreply@yourdomain.com

# -------------------------------------------
# Edge Function Secrets
# ⚠️  Generate unique values for production!
# -------------------------------------------
TOKEN_ENCRYPTION_KEY=GENERATE_32_CHAR_PRODUCTION_KEY!!
WEBHOOK_SECRET=GENERATE_UNIQUE_PRODUCTION_WEBHOOK_SECRET
MAKE_GOOGLE_EMAIL=your-production-make-integration-email

# -------------------------------------------
# Realtime Encryption Key
# -------------------------------------------
REALTIME_ENC_KEY=production-realtime-encryption-key

# -------------------------------------------
# Storage Backend (Optional: S3 for scalability)
# -------------------------------------------
STORAGE_BACKEND=file
# For S3:
# STORAGE_BACKEND=s3
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# S3_BUCKET=your-storage-bucket
# S3_REGION=us-east-1

# -------------------------------------------
# Backup Configuration
# -------------------------------------------
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket
BACKUP_S3_REGION=us-east-1

# -------------------------------------------
# Logging & Monitoring
# -------------------------------------------
LOG_LEVEL=warn

# -------------------------------------------
# Resource Limits (adjust based on server capacity)
# -------------------------------------------
# These are set in podman-compose.yml deploy.resources
