# ===========================================
# QA/Staging Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values
# Usage: cd environments/qa && cp .env.qa .env

# -------------------------------------------
# Domain Configuration
# -------------------------------------------
DOMAIN=qa.yourdomain.com
API_DOMAIN=api.qa.yourdomain.com
SITE_URL=https://qa.yourdomain.com
VITE_SUPABASE_URL=https://api.qa.yourdomain.com

# -------------------------------------------
# SSL Certificates (Let's Encrypt)
# Run: certbot certonly --standalone -d qa.yourdomain.com -d api.qa.yourdomain.com
# -------------------------------------------
SSL_CERT_PATH=/etc/letsencrypt/live/qa.yourdomain.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/qa.yourdomain.com/privkey.pem

# -------------------------------------------
# Database Configuration
# Use a STRONG password for QA!
# -------------------------------------------
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
POSTGRES_DB=postgres

# -------------------------------------------
# JWT & API Keys
# Generate with: ./scripts/generate-keys.sh
# -------------------------------------------
# IMPORTANT: Use a unique, strong secret (at least 32 characters)
JWT_SECRET=CHANGE_THIS_TO_A_UNIQUE_QA_JWT_SECRET_32_PLUS_CHARS

# Generate these using the generate-keys.sh script
ANON_KEY=GENERATE_WITH_SCRIPT
SERVICE_ROLE_KEY=GENERATE_WITH_SCRIPT

# -------------------------------------------
# Google OAuth
# Create QA-specific credentials in Google Cloud Console
# -------------------------------------------
GOOGLE_AUTH_ENABLED=true
GOOGLE_CLIENT_ID=your-qa-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-qa-google-client-secret

# -------------------------------------------
# SMTP Configuration (for real email delivery)
# -------------------------------------------
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_ADMIN_EMAIL=noreply@qa.yourdomain.com

# -------------------------------------------
# Edge Function Secrets
# -------------------------------------------
TOKEN_ENCRYPTION_KEY=qa-encryption-key-32-chars-long!!
WEBHOOK_SECRET=qa-webhook-secret-for-testing
MAKE_GOOGLE_EMAIL=your-make-integration-email

# -------------------------------------------
# Logging & Monitoring
# -------------------------------------------
LOG_LEVEL=info
